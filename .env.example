# =============================================================================
# Monsoon Assistant — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Supabase (Required)
# Get these from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI (Optional — for GenAI features)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (Alternative GenAI provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google Gemini (Primary GenAI provider — recommended)
GEMINI_API_KEY=your-gemini-api-key

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Monsoon Mitra"

# Feature Flags
NEXT_PUBLIC_ENABLE_MOCK_GENAI=false
NEXT_PUBLIC_ENABLE_PWA=true

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Error Tracking (Optional)
SENTRY_DSN=

# AI Provider: gemini | openai | anthropic
AI_PROVIDER=gemini
